<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Madison Renz — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,400;0,500;0,600;0,700;1,400;1,600&family=DM+Mono:wght@300;400;500&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
:root {
  --cream: #FAF7F2;
  --cream2: #EDEAE4;
  --ink: #0F0D0B;
  --purple: #2E2640;
  --purple-light: #4A3F5C;
  --purple-pale: #E8E5EE;
  --red: #B83232;
  --gold: #C9972A;
  --gold-pale: #FBF3E2;
  --mid: #1C1728;
  --sage: #3D5A4A;
  --sage-pale: #E4EDE8;
  --sand: #C4A882;
  --orange: #C45F1A;
  --orange-pale: #FEF0E6;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: 'Lato', sans-serif; background: var(--cream); color: var(--ink); overflow-x: hidden; }

/* ─── NAV ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; gap: 1.5rem;
  padding: 1.2rem 3.5rem;
  background: rgba(250,247,242,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(46,38,64,0.12);
  overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none;
}
nav::-webkit-scrollbar { display: none; }
.nav-logo { font-family: 'DM Mono', monospace; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--purple); font-weight: 500; flex-shrink: 0; }
.nav-links { display: flex; gap: 1.8rem; list-style: none; flex-shrink: 0; margin-left: auto; }
.nav-links a { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase; text-decoration: none; color: var(--ink); opacity: 0.45; transition: all 0.2s; white-space: nowrap; }
.nav-links a:hover { opacity: 1; color: var(--purple); }

/* ─── HERO ─── */
.hero { min-height: 100vh; display: grid; grid-template-columns: 1fr; padding-top: 68px; }
.hero.has-photo { grid-template-columns: 1.15fr 0.85fr; }
.hero-left { display: flex; flex-direction: column; justify-content: center; padding: 5rem 4rem 5rem 6rem; }
.hero-tag { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.24em; text-transform: uppercase; color: var(--purple); margin-bottom: 2rem; display: flex; align-items: center; gap: 0.9rem; }
.hero-tag::before { content: ''; display: block; width: 3rem; height: 1px; background: var(--purple); }
h1 { font-family: 'Cormorant', Georgia, serif; font-size: clamp(3.8rem, 5.5vw, 5.8rem); font-weight: 700; line-height: 1.0; letter-spacing: -0.01em; margin-bottom: 0.15em; }
h1 em { font-style: italic; color: var(--purple); }
.hero-subtitle { font-family: 'Cormorant', Georgia, serif; font-size: 1.18rem; color: #4A4458; margin: 1.6rem 0 2.5rem; line-height: 1.75; max-width: 30rem; font-weight: 400; }
.hero-badges { display: flex; gap: 0.65rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
.badge { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.38rem 0.85rem; background: var(--purple-pale); color: var(--purple); border: 1px solid rgba(46,38,64,0.2); }
.badge.gold { background: var(--gold-pale); color: #7A5A1A; border-color: rgba(201,151,42,0.3); }
.badge.orange { background: var(--orange-pale); color: var(--orange); border-color: rgba(196,95,26,0.25); }
.hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
.btn { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; padding: 0.85rem 1.8rem; border: 1.5px solid var(--ink); text-decoration: none; color: var(--ink); transition: all 0.25s; display: inline-flex; align-items: center; gap: 0.5rem; }
.btn:hover { background: var(--ink); color: var(--cream); }
.btn-fill { background: var(--purple); border-color: var(--purple); color: #fff; }
.btn-fill:hover { background: var(--mid); border-color: var(--mid); }
.hero-right { display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; background: var(--purple-pale); min-height: 0; }
.hero-right:empty, .hero-right.no-photo { display: none; }
.hero-photo-wrap { position: relative; z-index: 2; }
.hero-photo { width: 340px; height: 390px; object-fit: cover; object-position: center top; display: block; border: 4px solid white; box-shadow: 0 24px 64px rgba(46,38,64,0.22); }
.hero-photo[src=""] { display: none; }
.photo-accent { position: absolute; bottom: -18px; right: -18px; width: 100%; height: 100%; border: 2px solid var(--purple); z-index: -1; opacity: 0.5; }

/* ─── ANNOUNCEMENT ─── */
.announcement {
  background: var(--ink); color: var(--cream);
  padding: 3rem 6rem;
  display: grid; grid-template-columns: auto 1fr; gap: 3rem; align-items: center;
  border-top: 2px solid rgba(201,151,42,0.4);
}
.announce-eyebrow { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); margin-bottom: 0.7rem; display: flex; align-items: center; gap: 0.7rem; }
.announce-eyebrow::before { content: ''; display: block; width: 1.5rem; height: 1px; background: var(--gold); }
.announce-title { font-family: 'Cormorant', Georgia, serif; font-size: 1.85rem; font-weight: 700; line-height: 1.25; margin-bottom: 0.9rem; }
.announce-title em { font-style: italic; color: rgba(250,247,242,0.5); }
.announce-body { font-size: 0.95rem; opacity: 0.65; line-height: 1.8; max-width: 52rem; }
.announce-icon-wrap { width: 72px; height: 72px; border: 1px solid rgba(250,247,242,0.15); display: flex; align-items: center; justify-content: center; font-size: 2rem; flex-shrink: 0; }

/* ─── STATS ─── */
.stats-row { display: grid; grid-template-columns: repeat(4, 1fr); background: var(--ink); }
.stat { padding: 2.8rem 2rem; border-right: 1px solid rgba(255,255,255,0.07); text-align: center; }
.stat:last-child { border-right: none; }
.stat-num { font-family: 'Cormorant', Georgia, serif; font-size: 2.8rem; font-weight: 700; color: #B0AAC0; line-height: 1; margin-bottom: 0.5rem; }
.stat-label { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(255,255,255,0.4); }

/* ─── SHARED ─── */
section { padding: 7rem 6rem; }
.section-label { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--purple); margin-bottom: 0.8rem; display: flex; align-items: center; gap: 0.8rem; }
.section-label::before { content: ''; display: block; width: 2rem; height: 1px; background: var(--purple); }
h2 { font-family: 'Cormorant', Georgia, serif; font-size: clamp(2.2rem, 3vw, 3rem); font-weight: 700; line-height: 1.12; margin-bottom: 3.5rem; }
h2 em { font-style: italic; color: var(--purple); }

/* ─── EXPERIENCE ─── */
#experience { background: var(--cream2); }
.exp-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
.exp-card { background: var(--cream); padding: 3rem; transition: transform 0.3s; position: relative; border-top: 3px solid var(--purple); }
.exp-card:hover { transform: translateY(-4px); }
.exp-card.sundaze { border-top: 3px solid var(--orange); background: var(--cream); }
.exp-card.ut-role { border-top: 3px solid rgba(46,38,64,0.2); }
.exp-new-badge { font-family: 'DM Mono', monospace; font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; background: var(--orange); color: white; padding: 0.25rem 0.65rem; display: inline-block; margin-bottom: 1rem; }
.exp-date { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--purple); margin-bottom: 1.2rem; opacity: 0.65; }
.exp-card.sundaze .exp-date { color: var(--orange); opacity: 0.9; }
.exp-company { font-family: 'Cormorant', Georgia, serif; font-size: 1.6rem; font-weight: 700; margin-bottom: 0.2rem; line-height: 1.2; }
.exp-role { color: #4A4458; font-size: 0.93rem; margin-bottom: 1.4rem; font-weight: 300; }
.exp-card.sundaze .exp-role { color: #4A4458; }
.exp-list { list-style: none; padding: 0; }
.exp-list li { font-size: 0.9rem; line-height: 1.8; opacity: 0.72; padding: 0.22rem 0; padding-left: 1.4em; position: relative; }
.exp-list li::before { content: '›'; position: absolute; left: 0; color: var(--purple); font-size: 1.1em; }
.exp-card.sundaze .exp-list li::before { color: var(--orange); }
.exp-highlight { margin-top: 1.5rem; padding: 1rem 1.2rem; border-left: 3px solid var(--gold); background: rgba(201,151,42,0.07); font-size: 0.92rem; opacity: 0.85; line-height: 1.7; font-family: 'Cormorant', Georgia, serif; }
.exp-card.sundaze .exp-highlight { border-left-color: var(--orange); background: rgba(196,95,26,0.06); }
.exp-app-link { display: inline-flex; align-items: center; gap: 0.5rem; margin-top: 1.4rem; font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--orange); text-decoration: none; border-bottom: 1px solid rgba(196,95,26,0.35); padding-bottom: 2px; transition: opacity 0.2s; }
.exp-app-link:hover { opacity: 0.6; }
.exp-skills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.2rem; }
.exp-skill-tag { font-family: 'DM Mono', monospace; font-size: 0.54rem; letter-spacing: 0.09em; text-transform: uppercase; padding: 0.26rem 0.6rem; border: 1px solid rgba(196,95,26,0.3); color: var(--orange); }

/* ─── CERTS ─── */
#certs { background: var(--cream); }
.certs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
.cert-card { padding: 2rem; border: 1.5px solid rgba(46,38,64,0.15); transition: border-color 0.2s, transform 0.2s; }
.cert-card:hover { border-color: var(--purple); transform: translateY(-3px); }
.cert-icon { font-size: 1.8rem; margin-bottom: 1rem; }
.cert-name { font-family: 'Cormorant', Georgia, serif; font-size: 1.1rem; font-weight: 600; margin-bottom: 0.3rem; line-height: 1.3; }
.cert-detail { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; color: var(--purple); opacity: 0.65; }
.cert-card.featured { background: linear-gradient(135deg, var(--purple-pale), #E0D8EE); border-color: rgba(46,38,64,0.35); }
.cert-card.featured .cert-name { color: var(--purple); }

/* ─── SKILLS ─── */
#skills { background: var(--cream2); }
.skills-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; }
.skill-category-label { font-family: 'DM Mono', monospace; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--purple); opacity: 0.65; margin-bottom: 1.1rem; }
.skill-tags { display: flex; flex-wrap: wrap; gap: 0.55rem; margin-bottom: 2.5rem; }
.skill-tag { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.42rem 0.85rem; border: 1px solid rgba(46,38,64,0.18); color: var(--ink); opacity: 0.65; transition: all 0.2s; }
.skill-tag:hover, .skill-tag.accent { border-color: var(--purple); color: var(--purple); opacity: 1; background: var(--purple-pale); }

/* ─── EDUCATION ─── */
#education { background: var(--cream); }
.edu-list { display: flex; flex-direction: column; gap: 1.5rem; }
.edu-card { display: grid; grid-template-columns: 1fr auto; gap: 2rem; align-items: start; border-left: 4px solid var(--purple); padding: 2.2rem 2.5rem; background: var(--cream2); }
.edu-card.abroad { border-left-color: var(--gold); }
.edu-school { font-family: 'Cormorant', Georgia, serif; font-size: 1.6rem; font-weight: 700; margin-bottom: 0.35rem; line-height: 1.2; }
.edu-degree { color: #4A4458; font-size: 0.95rem; margin-bottom: 0.8rem; font-weight: 300; }
.edu-detail { font-family: 'DM Mono', monospace; font-size: 0.62rem; letter-spacing: 0.1em; opacity: 0.5; display: flex; gap: 1.5rem; flex-wrap: wrap; }
.edu-year { font-family: 'Cormorant', Georgia, serif; font-size: 2.5rem; font-weight: 700; color: var(--purple); white-space: nowrap; padding-right: 2rem; }
.edu-card.abroad .edu-year { color: var(--gold); }

/* ─── NETWORK ─── */
#network { background: var(--ink); color: var(--cream); padding: 7rem 6rem; }
#network .section-label { color: rgba(201,151,42,0.8); }
#network .section-label::before { background: rgba(201,151,42,0.8); }
#network h2 { color: var(--cream); }
#network h2 em { color: rgba(250,247,242,0.35); }
.network-intro { font-size: 0.95rem; color: rgba(250,247,242,0.5); line-height: 1.9; max-width: 52rem; margin-bottom: 3.5rem; }
.network-table { width: 100%; border-collapse: collapse; }
.network-table thead tr { border-bottom: 1px solid rgba(250,247,242,0.08); }
.network-table th { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(250,247,242,0.32); padding: 0 1rem 1rem 0; text-align: left; font-weight: 400; }
.network-table tbody tr { border-bottom: 1px solid rgba(250,247,242,0.04); transition: background 0.2s; }
.network-table tbody tr:hover { background: rgba(255,255,255,0.03); }
.network-table td { padding: 0.9rem 1rem 0.9rem 0; vertical-align: middle; }
.td-name { font-family: 'Cormorant', Georgia, serif; font-size: 1.05rem; font-weight: 600; color: var(--cream); white-space: nowrap; }
.td-title { font-size: 0.84rem; color: rgba(250,247,242,0.55); line-height: 1.4; }
.td-company { font-family: 'DM Mono', monospace; font-size: 0.68rem; letter-spacing: 0.08em; color: var(--sand); white-space: nowrap; }
.td-date { font-family: 'DM Mono', monospace; font-size: 0.62rem; color: rgba(250,247,242,0.28); white-space: nowrap; }

/* ─── CONTACT ─── */
#contact { background: var(--purple); color: white; text-align: center; padding: 8rem 4rem; }
#contact .section-label { justify-content: center; color: rgba(255,255,255,0.45); }
#contact .section-label::before { background: rgba(255,255,255,0.35); }
#contact h2 { color: white; margin-bottom: 1rem; }
#contact h2 em { color: rgba(255,255,255,0.4); }
#contact p { font-family: 'Cormorant', Georgia, serif; font-size: 1.2rem; opacity: 0.65; margin-bottom: 3rem; line-height: 1.8; max-width: 36rem; margin-left: auto; margin-right: auto; }
.contact-links { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
.btn-light { border-color: rgba(255,255,255,0.45); color: white; }
.btn-light:hover { background: white; color: var(--purple); border-color: white; }

/* ─── FOOTER ─── */
footer { background: var(--mid); color: white; padding: 2rem 6rem; display: flex; justify-content: space-between; align-items: center; }
footer span { font-family: 'DM Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; opacity: 0.35; }

/* ─── REVEAL ─── */
.reveal { opacity: 0; transform: translateY(26px); transition: opacity 0.75s ease, transform 0.75s ease; }
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ─── RESPONSIVE ─── */
@media (max-width: 1000px) {
  nav { padding: 1.1rem 1.5rem; }
  .nav-links { gap: 1.2rem; margin-left: 0; }
  .hero { grid-template-columns: 1fr; }
  .hero-left { padding: 4rem 2rem 2rem; }
  .hero-right { padding: 3rem 2rem; min-height: 380px; }
  .hero-photo { width: 260px; height: 300px; }
  .announcement { padding: 2.5rem 2rem; grid-template-columns: 1fr; gap: 1rem; }
  .announce-icon-wrap { display: none; }
  .stats-row { grid-template-columns: 1fr 1fr; }
  section { padding: 5rem 2rem; }
  .exp-grid { grid-template-columns: 1fr; }
  .certs-grid { grid-template-columns: 1fr 1fr; }
  .skills-layout { grid-template-columns: 1fr; gap: 2.5rem; }
  .edu-card { grid-template-columns: 1fr; }
  .edu-year { display: none; }
  #network { padding: 5rem 2rem; }
  .network-table th:nth-child(4), .network-table td:nth-child(4) { display: none; }
  footer { flex-direction: column; gap: 1rem; text-align: center; padding: 2rem; }
}
</style>
</head>
