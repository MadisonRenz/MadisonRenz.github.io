<script>
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); } });
}, { threshold: 0.1 });
document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

// Hide hero-right panel if no photo loads
const heroPhoto = document.querySelector('.hero-photo');
const heroRight = document.querySelector('.hero-right');
const hero = document.querySelector('.hero');
if (heroPhoto && heroRight) {
  if (!heroPhoto.src || heroPhoto.src === window.location.href) {
    heroRight.style.display = 'none';
  } else {
    heroPhoto.addEventListener('load', () => { hero.classList.add('has-photo'); });
    heroPhoto.addEventListener('error', () => { heroRight.style.display = 'none'; });
  }
}
</script>
